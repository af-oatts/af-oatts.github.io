---
import { BUILD_TARGETS } from "../lib/constants";
import { getLatestRelease, getVersionNumber } from "../services/getDownloads";
import {
  getMacosArmAssets,
  getMacosIntelAssets,
  getAppimageAssets,
  getDebAssets,
  getExeWindowsAssets,
  getMSIWindowsAssets,
} from "../services/github";

const latestRelease = await getLatestRelease();
const versionNumber = getVersionNumber(latestRelease);
const tagName = latestRelease.tag_name;

const macArm = getMacosArmAssets(latestRelease.assets);
const macIntel = getMacosIntelAssets(latestRelease.assets);
const appimage = getAppimageAssets(latestRelease.assets);
const exe = getExeWindowsAssets(latestRelease.assets);
const msi = getMSIWindowsAssets(latestRelease.assets);
const deb = getDebAssets(latestRelease.assets);
---

<div class="dl-card-wrap px-3">
  <div class="dl-card p-4 p-md-5">
    <div class="d-flex align-items-center gap-3 mb-3">
      <div>
        <h1 class="h4 m-0">Download OATTS</h1>
        <div class="text-body-secondary small"></div>
      </div>
    </div>

    <div id="osGroup" class="d-flex flex-wrap gap-2 mb-4">
      <label
        class="btn os-pill px-3 py-2"
        data-os={BUILD_TARGETS.WINDOWS_EXE}
        data-asset={exe[0]?.name}
        data-download={exe[0]?.browser_download_url}
      >
        <input
          type="radio"
          name="os"
          disabled={!exe[0]}
          value={BUILD_TARGETS.WINDOWS_EXE}
        />
        Windows Installer (EXE)
      </label>
      <label
        class="btn os-pill px-3 py-2"
        data-os={BUILD_TARGETS.WINDOWS_MSI}
        data-asset={msi[0]?.name}
        data-download={msi[0]?.browser_download_url}
      >
        <input
          type="radio"
          name="os"
          disabled={!msi[0]}
          value={BUILD_TARGETS.WINDOWS_MSI}
        />
        Windows Installer (MSI)
      </label>
      <label
        class="btn os-pill px-3 py-2"
        data-os={BUILD_TARGETS.MAC_OS_ARM}
        data-asset={macArm[0]?.name}
        data-download={macArm[0]?.browser_download_url}
      >
        <input
          type="radio"
          name="os"
          disabled={!macArm[0]}
          value={BUILD_TARGETS.MAC_OS_ARM}
        />
        macOS (Apple Silicon)
      </label>
      <label
        class="btn os-pill px-3 py-2"
        data-os={BUILD_TARGETS.MAC_OS_INTEL}
        data-asset={macIntel[0]?.name}
        data-download={macIntel[0]?.browser_download_url}
      >
        <input
          type="radio"
          name="os"
          disabled={!macIntel[0]}
          value={BUILD_TARGETS.MAC_OS_INTEL}
        />
        macOS (Intel)
      </label>
      <label
        class="btn os-pill px-3 py-2"
        data-os={BUILD_TARGETS.LINUX}
        data-asset={appimage[0]?.name}
        data-download={appimage[0]?.browser_download_url}
      >
        <input
          type="radio"
          name="os"
          disabled={!appimage[0]}
          value={BUILD_TARGETS.LINUX}
        />
        Linux (AppImage)
      </label>
    </div>

    <div class="d-grid">
      <a
        id="downloadBtn"
        class="btn btn-primary btn-lg px-4 py-3 fw-bold"
        data-explode
        download
      >
        Download
      </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
      <span class="text-body-secondary small">{versionNumber}</span>
      <a
        id="checksumsLink"
        class="link-light link-underline-opacity-25 small"
        href="/releases"
      >
        Checksums & notes
      </a>
    </div>
  </div>
</div>

<style>
  .dl-card-wrap {
    position: relative;
    display: grid;
    place-items: center;
  }
  .dl-card {
    position: relative;
    z-index: 1;
    width: min(560px, 92vw);
    border-radius: 20px;

    background: var(--bs-body-bg);

    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55);
  }
  .dl-card-wrap::after {
    content: "";
    position: absolute;
    inset: -84px;
    pointer-events: none;

    z-index: 0;

    background: radial-gradient(
      140% 120% at 50% 50%,
      var(--bs-body-bg) 0%,
      color-mix(in srgb, var(--bs-body-bg) 85%, transparent) 55%,
      transparent 85%
    );
    filter: blur(28px);
  }

  .os-pill {
    user-select: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #cfe0ff;
    background: rgba(94, 160, 255, 0.08);
  }

  .os-pill:has(input:disabled) {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }
  .os-pill input {
    display: none;
  }
  .os-pill.active {
    color: #0b0f19;
    background: #5ea0ff;
    border-color: transparent;
  }
</style>

<script
  is:inline
  define:vars={{ BUILD_TARGETS, tagName, macArm, macIntel, appimage, msi, exe }}
>
  function detectOS() {
    const ua = navigator.userAgent || "";
    const plat = navigator.platform || "";
    if (/Windows/i.test(ua) || /Win/i.test(plat))
      return BUILD_TARGETS.WINDOWS_EXE;
    if (/Mac/i.test(ua) || /Mac/i.test(plat)) {
      const isArmHint = /Apple|ARM|aarch64|arm64/i.test(ua);
      return isArmHint ? BUILD_TARGETS.MAC_OS_ARM : BUILD_TARGETS.MAC_OS_INTEL;
    }
    if (/Linux|X11/i.test(ua)) return BUILD_TARGETS.LINUX;
    return BUILD_TARGETS.WINDOWS_EXE;
  }

  function autoselectAsset() {
    switch (selectedOS) {
      case BUILD_TARGETS.MAC_OS_ARM:
        return macArm[0].name;
      case BUILD_TARGETS.MAC_OS_INTEL:
        return macIntel[0].name;
      case BUILD_TARGETS.WINDOWS_EXE:
        return exe[0].name;
      case BUILD_TARGETS.WINDOWS_MSI:
        return msi[0].name;
      case BUILD_TARGETS.LINUX:
        return appimage[0].name;
    }
  }

  function autoselectDownloadURL() {
    switch (selectedOS) {
      case BUILD_TARGETS.MAC_OS_ARM:
        return macArm[0].browser_download_url;
      case BUILD_TARGETS.MAC_OS_INTEL:
        return macIntel[0].browser_download_url;
      case BUILD_TARGETS.WINDOWS_EXE:
        return exe[0].browser_download_url;
      case BUILD_TARGETS.WINDOWS_MSI:
        return msi[0].browser_download_url;
      case BUILD_TARGETS.LINUX:
        return appimage[0].browser_download_url;
    }
  }

  const osGroup = document.getElementById("osGroup");
  const downloadBtn = document.getElementById("downloadBtn");
  let selectedOS = detectOS();
  let selectedAsset = autoselectAsset();
  let selectedDownloadURL = autoselectDownloadURL();

  function setActive(osKey, asset, download) {
    selectedOS = osKey;
    selectedAsset = asset;
    selectedDownloadURL = download;
    osGroup.querySelectorAll(".os-pill").forEach((lbl) => {
      const active = lbl.getAttribute("data-os") === osKey;
      lbl.classList.toggle("active", active);
      const input = lbl.querySelector("input");
      if (input) input.checked = active;
    });
    downloadBtn.href = selectedDownloadURL;
  }

  setActive(selectedOS, selectedAsset, selectedDownloadURL);

  osGroup.addEventListener("click", (e) => {
    const lbl = e.target.closest(".os-pill");
    if (!lbl) return;
    const osKey = lbl.getAttribute("data-os");
    const asset = lbl.getAttribute("data-asset");
    const download = lbl.getAttribute("data-download");
    if (osKey && asset && download) setActive(osKey, asset, download);
  });

  downloadBtn.addEventListener("click", () => {
    const ev = new CustomEvent("downloaded", {
      detail: { releaseTag: tagName, os: selectedOS, asset: selectedAsset },
      bubbles: true,
    });
    downloadBtn.dispatchEvent(ev);
  });
</script>
